export function getStaticPaths() {
  const allServices = [
    { slug: 'botox-dysport' }, { slug: 'dermal-fillers' }, { slug: 'sculptra' },
    { slug: 'skin-boosters' }, { slug: 'vamp' }, { slug: 'laser-treatments' },
    { slug: 'laser-facials' }, { slug: 'potenza' }, { slug: 'microneedling' },
    { slug: 'prp' }, { slug: 'chemical-peels' }, { slug: 'sclerotherapy' },
    { slug: 'latisse' }, { slug: 'visia-analysis' }, { slug: 'lesion-removal' },
    { slug: 'consultation' }, { slug: 'skinceuticals' }, { slug: 'vivier' },
    { slug: 'eltamd' }, { slug: 'skinbetter' },
  ];
  return allServices.map(s => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = services.find(s => s.slug === slug)!;

// Build related services array
const relatedServices = service.related
  .map(r => services.find(s => s.slug === r))
  .filter(Boolean);

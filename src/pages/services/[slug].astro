/* ── Related ── */
.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-top: 3rem;
}
.related-card {
  display: flex;
  flex-direction: column;
  background: var(--white);
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease);

.benefits-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-top: 3rem;
  list-style: none;
}
.benefit-card {
  background: var(--white);
  padding: 2rem 1.75rem;
  border-bottom: 2px solid var(--rose);
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}
.benefit-card__icon {
  color: var(--rose);
  font-size: 0.75rem;
  flex-shrink: 0;
  margin-top: 0.35rem;
}
.benefit-card p {
  font-family: 'Open Sans', sans-serif;
  font-size: 0.88rem;
  line-height: 1.7;
  color: var(--charcoal);
  margin: 0;
}

/* ── Process ── */
.process-steps {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 3rem;
  list-style: none;
  counter-reset: none;
  max-width: 780px;
  margin-inline: auto;
}
.process-step {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 2rem;
  padding: 2.5rem 0;
  border-bottom: 1px solid rgba(213,164,148,0.2);

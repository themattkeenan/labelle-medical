}
.process-step:first-child { padding-top: 0; }
.process-step:last-child { border-bottom: none; }
.process-step__num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 3.5rem;
  font-weight: 300;
  color: var(--rose);
  line-height: 1;
  opacity: 0.4;
}
.process-step__title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.4rem;

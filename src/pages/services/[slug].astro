/* ── FAQ ── */
.svc-faq__inner {
  display: grid;
  grid-template-columns: 1fr 1.8fr;
  gap: 6rem;
  align-items: start;
}
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.faq-item {
  border-bottom: 1px solid rgba(213,164,148,0.25);
}
.faq-item__btn {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 1.25rem 0;
  text-align: left;
  font-family: 'Open Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--charcoal);
  cursor: pointer;
  gap: 1rem;

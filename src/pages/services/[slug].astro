<Layout
  title={`${service.title} — La Belle Medical Aesthetic Clinic`}
  description={service.metaDesc}
>

  <!-- Hero -->
  <section class="svc-hero">
    <div class="svc-hero__bg">
      <img
        src={service.heroImg}
        alt={service.title}
        loading="eager"
        fetchpriority="high"
        width="1400"
        height="700"
      />
      <div class="svc-hero__overlay"></div>
    </div>
    <div class="container svc-hero__content">
      <a href="/services" class="svc-hero__back">← All Services</a>
      <p class="eyebrow" style="color:var(--rose)">{service.tagline}</p>
      <h1 style="color:var(--white)">{service.title}</h1>
      <div class="divider"></div>
      <a
        href="https://labellemedicalclinic.janeapp.com/"
        target="_blank"
        rel="noopener"
        class="btn btn--primary"
      >
        Book This Treatment
      </a>
    </div>
  </section>

  <!-- Intro -->
  <section class="section svc-intro">
    <div class="container svc-intro__grid">
      <div class="svc-intro__text" data-reveal>
        <p class="eyebrow">Overview</p>
        <h2>About This Treatment</h2>
        <div class="divider divider--left"></div>
        <p class="lead">{service.intro}</p>
        <a
          href="https://labellemedicalclinic.janeapp.com/"
          target="_blank"
          rel="noopener"
          class="btn btn--outline"
          style="margin-top:2rem"
        >
          Book a Consultation
        </a>
      </div>
      <div class="svc-intro__image" data-reveal data-delay="150">
        <img
          src={service.heroImg}
          alt={service.title}
          loading="lazy"
          width="600"
          height="700"
        />
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="section svc-benefits" style="background:var(--cream-dark)">
    <div class="container">
      <div class="text-center" data-reveal="fade">
        <p class="eyebrow">Why Choose This Treatment</p>
        <h2>Key Benefits</h2>
        <div class="divider"></div>
      </div>
      <ul class="benefits-grid">
        {service.benefits.map((b, i) => (
          <li class="benefit-card" data-reveal data-delay={String((i % 3 + 1) * 100)}>
            <span class="benefit-card__icon" aria-hidden="true">✦</span>
            <p>{b}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Process -->
  <section class="section svc-process">
    <div class="container">
      <div class="text-center" data-reveal="fade">
        <p class="eyebrow">What to Expect</p>
        <h2>Your Treatment Journey</h2>
        <div class="divider"></div>
      </div>
      <ol class="process-steps">
        {service.process.map((step, i) => (
          <li class="process-step" data-reveal data-delay={String((i + 1) * 100)}>
            <span class="process-step__num">{String(i + 1).padStart(2, '0')}</span>
            <div class="process-step__content">
              <h3 class="process-step__title">{step.step}</h3>
              <p class="process-step__desc">{step.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section svc-faq" style="background:var(--cream-dark)">
    <div class="container svc-faq__inner">
      <div data-reveal="fade">
        <p class="eyebrow">Common Questions</p>
        <h2>Frequently Asked Questions</h2>
        <div class="divider divider--left"></div>
      </div>
      <dl class="faq-list">
        {service.faqs.map((faq, i) => (
          <div class="faq-item" data-reveal data-delay={String((i + 1) * 80)}>
            <dt class="faq-item__q">
              <button class="faq-item__btn" aria-expanded="false">
                {faq.q}
                <span class="faq-item__icon" aria-hidden="true">+</span>
              </button>
            </dt>
            <dd class="faq-item__a">
              <p>{faq.a}</p>
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServices.length > 0 && (
    <section class="section svc-related">
      <div class="container">
        <div class="text-center" data-reveal="fade">
          <p class="eyebrow">You May Also Like</p>
          <h2>Related Treatments</h2>
          <div class="divider"></div>
        </div>
        <div class="related-grid">
          {relatedServices.map((r, i) => (
            <a href={`/services/${r!.slug}`} class="related-card" data-reveal data-delay={String((i + 1) * 100)}>
              <div class="related-card__img">
                <img src={r!.heroImg} alt={r!.title} loading="lazy" width="400" height="300" />
              </div>
              <div class="related-card__body">
                <h3 class="related-card__title">{r!.title}</h3>
                <p class="related-card__tag">{r!.tagline}</p>
                <span class="related-card__link">Learn More →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section svc-cta" style="background:var(--charcoal)">
    <div class="container text-center">
      <p class="eyebrow" style="color:var(--rose)" data-reveal="fade">Ready to Get Started?</p>
      <h2 style="color:var(--white)" data-reveal data-delay="100">Book Your {service.title} Consultation</h2>
      <div class="divider" data-reveal="fade" data-delay="200"></div>
      <p style="color:rgba(255,255,255,0.7); max-width:54ch; margin-inline:auto" data-reveal data-delay="200">
        Our experienced team is here to answer your questions and design a personalized treatment plan tailored to your unique skin and goals.
      </p>
      <div class="svc-cta__actions" data-reveal data-delay="300">
        <a href="https://labellemedicalclinic.janeapp.com/" target="_blank" rel="noopener" class="btn btn--primary">
          Book Online
        </a>
        <a href="/contact" class="btn btn--outline-white">Contact Us</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ── Hero ── */
.svc-hero {
  position: relative;
  height: 70vh;
  min-height: 460px;
  display: flex;
  align-items: flex-end;
  padding-bottom: 5rem;
}
.svc-hero__bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}
.svc-hero__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
}
.svc-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.25) 60%, rgba(0,0,0,0.1) 100%);
}
.svc-hero__content {
  position: relative;
  z-index: 1;
}
.svc-hero__back {
  display: inline-block;
  font-family: 'Open Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 400;
  letter-spacing: 0.05em;
  color: rgba(255,255,255,0.65);
  margin-bottom: 1.5rem;
  transition: color 0.3s;
}
.svc-hero__back:hover { color: var(--rose); }
.svc-hero__content h1 {
  margin-top: 0.5rem;
  font-size: clamp(2.4rem, 5vw, 4.5rem);
}

/* ── Intro ── */
.svc-intro__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: center;
}
.svc-intro__image {

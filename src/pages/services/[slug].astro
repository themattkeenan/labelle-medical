</style>

<script>
// FAQ accordion
document.querySelectorAll<HTMLButtonElement>('.faq-item__btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    // Close all
    document.querySelectorAll<HTMLButtonElement>('.faq-item__btn').forEach(b => {
      b.setAttribute('aria-expanded', 'false');
      const a = b.closest('.faq-item')?.querySelector<HTMLElement>('.faq-item__a');
      if (a) a.style.maxHeight = '0';
    });
    // Open clicked if was closed
    if (!isOpen) {
      btn.setAttribute('aria-expanded', 'true');
      const answer = btn.closest('.faq-item')?.querySelector<HTMLElement>('.faq-item__a');
      if (answer) answer.style.maxHeight = answer.scrollHeight + 'px';
    }
  });
});
</script>

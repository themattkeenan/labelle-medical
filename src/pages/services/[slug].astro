}
.related-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 48px rgba(0,0,0,0.12);
}
.related-card__img {
  overflow: hidden;
  height: 220px;
}
.related-card__img img {
  width: 100%;

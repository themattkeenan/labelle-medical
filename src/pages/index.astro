---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Botox® & Dysport®',
    desc: 'Smooth fine lines and wrinkles with precision neuromodulator treatments tailored to your facial anatomy.',
    href: '/services/botox-dysport',
    icon: '✦',
  },
  {
    title: 'Dermal Fillers',
    desc: 'Restore lost volume, enhance contours and rejuvenate with Juvederm®, Revanesse® and Restylane®.',
    href: '/services/dermal-fillers',
    icon: '◆',
  },
  {
    title: 'Laser Treatments',
    desc: 'Advanced laser technology targeting pigmentation, redness, rosacea and unwanted hair removal.',
    href: '/services/laser-treatments',
    icon: '◈',
  },
  {
    title: 'Sculptra®',
    desc: 'Stimulate your skin\'s own collagen for gradual, natural volume restoration that lasts up to two years.',
    href: '/services/sculptra',
    icon: '◉',
  },
  {
    title: 'Microneedling',
    desc: 'SkinPen medical-grade microneedling to resurface, tighten and dramatically improve skin texture.',
    href: '/services/microneedling',
    icon: '◍',
  },
  {
    title: 'PRP Therapy',
    desc: 'Harness your body\'s own growth factors to accelerate healing, rejuvenation and hair restoration.',
    href: '/services/prp',
    icon: '◎',
  },
  {
    title: 'Chemical Peels',
    desc: 'Medical-grade peels to renew your complexion — reducing acne, hyperpigmentation and sun damage.',
    href: '/services/chemical-peels',
    icon: '◇',
  },
  {
    title: 'Sclerotherapy',
    desc: 'Clinically proven treatment to eliminate spider veins and restore smooth, even-toned legs.',
    href: '/services/sclerotherapy',
    icon: '◈',
  },
  {
    title: 'Skin Boosters',
    desc: 'Deep hydration injections that plump from within, giving your skin a luminous, glass-skin glow.',
    href: '/services/skin-boosters',
    icon: '◑',
  },
];

const testimonials = [
  {
    quote: "I was so nervous about getting Botox for the first time, but the team at La Belle made me feel completely at ease. The results are so natural — I look refreshed, not frozen.",
    author: "Sarah M.",
    location: "Quispamsis",
  },
  {
    quote: "Absolutely love this clinic. The staff is incredibly knowledgeable and genuinely care about giving you results that enhance your natural beauty. My skin has never looked better.",
    author: "Jennifer L.",
    location: "Saint John",
  },
  {
    quote: "I've been going to La Belle for over a year now for laser treatments and the results have been amazing. Professional, clean, and they always make me feel so comfortable.",
    author: "Amanda K.",
    location: "Hampton",
  },
];

const brands = ['SkinCeuticals®', 'Vivier Skin', 'EltaMD', 'Skinbetter Science', 'Colorescience', 'Hydrinity'];
---

<Layout
  title="Botox Quispamsis | Medical Aesthetics | Laser Hair Removal | La Belle"
  description="La Belle Medical Aesthetic Clinic — Nurse Practitioner-owned luxury skin treatments in Quispamsis, NB. Botox, dermal fillers, laser treatments, microneedling and more. Book today."
  transparentHeader={true}
>

  <!-- ═══════════════════════════════════════
       HERO
  ═══════════════════════════════════════ -->
  <section class="hero" aria-label="Hero">
    <div class="hero__bg">
      <img
        src="/images/686bc870fc98b09e4ae01b7d_optimized_1920.jpg"
        alt="La Belle Medical Aesthetic Clinic"
        class="hero__img"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
      />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content container">
      <div class="hero__text">
        <p class="hero__eyebrow" data-reveal="fade">Quispamsis, New Brunswick</p>
        <h1 class="hero__title" data-reveal data-delay="100">
          Feel Your Best,<br>
          <em>Inside &amp; Out</em>
        </h1>
        <p class="hero__subtitle" data-reveal data-delay="200">
          Luxury medical aesthetics by a Nurse Practitioner dedicated to enhancing your natural beauty with precision, safety and care.
        </p>
        <div class="hero__actions" data-reveal data-delay="300">
          <a href="https://labellemedicalclinic.janeapp.com/" target="_blank" rel="noopener" class="btn btn--rose">
            Book a Consultation
          </a>
          <a href="/services" class="btn btn--outline-white">
            Explore Services
          </a>
        </div>
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <span>Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       TRUST BAR
  ═══════════════════════════════════════ -->
  <section class="trust-bar" aria-label="Credentials">
    <div class="container">
      <ul class="trust-bar__list">
        <li class="trust-bar__item" data-reveal="fade" data-delay="100">
          <span class="trust-bar__icon">✦</span>
          <span>Nurse Practitioner–Owned</span>
        </li>
        <li class="trust-bar__item" data-reveal="fade" data-delay="200">
          <span class="trust-bar__icon">✦</span>
          <span>Medical-Grade Treatments</span>
        </li>
        <li class="trust-bar__item" data-reveal="fade" data-delay="300">
          <span class="trust-bar__icon">✦</span>
          <span>Personalized Care Plans</span>
        </li>
        <li class="trust-bar__item" data-reveal="fade" data-delay="400">
          <span class="trust-bar__icon">✦</span>
          <span>Natural, Safe Results</span>
        </li>
        <li class="trust-bar__item" data-reveal="fade" data-delay="500">
          <span class="trust-bar__icon">✦</span>
          <span>Serving All of New Brunswick</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       ABOUT INTRO
  ═══════════════════════════════════════ -->
  <section class="about-intro section" aria-labelledby="about-heading">
    <div class="container">
      <div class="about-intro__grid">
        <div class="about-intro__images">
          <div class="about-intro__img-wrap about-intro__img-wrap--main" data-reveal="left">
            <img
              src="/images/668d6e3314180d551caab1ca_optimized_1396.jpg"
              alt="La Belle Medical Aesthetic Clinic interior"
              loading="lazy"
              width="700"
              height="900"
            />
          </div>
          <div class="about-intro__img-wrap about-intro__img-wrap--accent" data-reveal="left" data-delay="200">
            <img
              src="/images/67b60d5a95c836c5b5e1b6b7_optimized_570_c570x579-0x0.jpg"
              alt="Medical aesthetic treatment"
              loading="lazy"
              width="300"
              height="380"
            />
          </div>
          <div class="about-intro__badge" data-reveal="fade" data-delay="400">
            <span class="about-intro__badge-num">5★</span>
            <span class="about-intro__badge-text">Rated Clinic<br>in Quispamsis</span>
          </div>
        </div>

        <div class="about-intro__content">
          <p class="eyebrow" data-reveal="fade">About La Belle</p>
          <h2 id="about-heading" data-reveal data-delay="100">
            Where Expertise Meets<br>Artistry
          </h2>
          <div class="divider divider--left" data-reveal="fade" data-delay="200"></div>
          <p class="lead" data-reveal data-delay="200">
            Located in Quispamsis, New Brunswick, La Belle Medical Aesthetic Clinic is Nurse Practitioner-owned — ensuring every treatment is delivered with the highest clinical standards and genuine care for your wellbeing.
          </p>
          <p data-reveal data-delay="300">
            We believe beauty treatments should enhance who you already are, never change it. Our personalized approach means we take the time to truly understand your goals, crafting a treatment plan designed specifically for you.
          </p>
          <div class="about-intro__stats" data-reveal data-delay="400">
            <div class="stat">
              <span class="stat__num">22+</span>
              <span class="stat__label">Services Offered</span>
            </div>
            <div class="stat">
              <span class="stat__num">NP</span>
              <span class="stat__label">Owned & Operated</span>
            </div>
            <div class="stat">
              <span class="stat__num">100%</span>
              <span class="stat__label">Personalized Care</span>
            </div>
          </div>
          <a href="/about" class="btn btn--outline" data-reveal data-delay="500">Meet Our Team</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SERVICES
  ═══════════════════════════════════════ -->
  <section class="services section" aria-labelledby="services-heading">
    <div class="services__bg-accent" aria-hidden="true"></div>
    <div class="container">
      <div class="section-header text-center" data-reveal="fade">
        <p class="eyebrow">What We Offer</p>
        <h2 id="services-heading">Expert Treatments,<br>Exceptional Results</h2>
        <div class="divider"></div>
        <p class="lead">From injectables to advanced laser technology, every treatment is administered with clinical precision and an artist's eye.</p>
      </div>

      <div class="services__grid">
        {services.map((service, i) => (
          <a href={service.href} class="service-card" data-reveal data-delay={String(((i % 3) + 1) * 100)}>
            <span class="service-card__icon" aria-hidden="true">{service.icon}</span>
            <h3 class="service-card__title">{service.title}</h3>
            <p class="service-card__desc">{service.desc}</p>
            <span class="service-card__cta">Learn More <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>

      <div class="services__footer text-center" data-reveal data-delay="200">
        <p>Not sure which treatment is right for you?</p>
        <a href="/contact" class="btn btn--primary">Book a Free Consultation</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       FEATURE / FULL-WIDTH IMAGE
  ═══════════════════════════════════════ -->
  <section class="feature-image" aria-hidden="true">
    <div class="feature-image__inner">
      <img
        src="/images/668d70ef927cf1a08b28e7e4_optimized_1395_c1395x931-0x0.jpg"
        alt="Medical aesthetic treatment at La Belle"
        loading="lazy"
        width="1400"
        height="700"
      />
      <div class="feature-image__overlay">
        <div class="container">
          <blockquote class="feature-quote" data-reveal="fade">
            <p>"At La Belle, we work with you — not on you."</p>
            <footer>Our Philosophy</footer>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       TREATMENT PROCESS
  ═══════════════════════════════════════ -->
  <section class="process section" aria-labelledby="process-heading">
    <div class="container">
      <div class="section-header text-center" data-reveal="fade">
        <p class="eyebrow">Your Journey</p>
        <h2 id="process-heading">The La Belle Experience</h2>
        <div class="divider"></div>
      </div>

      <div class="process__steps">
        <div class="process__step" data-reveal data-delay="100">
          <div class="process__num" aria-hidden="true">01</div>
          <div class="process__content">
            <h3>Consultation</h3>
            <p>A comprehensive evaluation of your face and skin, followed by tailored recommendations — skincare routines, injectables, facials, and laser procedures — all customized to your specific goals.</p>
          </div>
        </div>

        <div class="process__connector" aria-hidden="true"></div>

        <div class="process__step" data-reveal data-delay="200">
          <div class="process__num" aria-hidden="true">02</div>
          <div class="process__content">
            <h3>Treatment</h3>
            <p>Our highly trained medical providers guide you through each stage, ensuring your goals are met with precision. Depending on your objectives, you may enjoy a carefully coordinated series of appointments.</p>
          </div>
        </div>

        <div class="process__connector" aria-hidden="true"></div>

        <div class="process__step" data-reveal data-delay="300">
          <div class="process__num" aria-hidden="true">03</div>
          <div class="process__content">
            <h3>Results & Follow-Up</h3>
            <p>We document your progress with before-and-after photos and provide complimentary skincare follow-ups to ensure your treatment plan is effective and optimized for your evolving needs.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       GALLERY PREVIEW
  ═══════════════════════════════════════ -->
  <section class="gallery-preview section" aria-labelledby="gallery-heading">
    <div class="container">
      <div class="section-header text-center" data-reveal="fade">
        <p class="eyebrow">Results Speak</p>
        <h2 id="gallery-heading">Our Work</h2>
        <div class="divider"></div>
      </div>

      <div class="gallery-preview__grid">
        <div class="gallery-preview__item gallery-preview__item--tall" data-reveal="left">
          <img src="/images/6866d81ccd186242532d7d09_optimized_929_c929x1396-0x0.jpg" alt="Treatment result" loading="lazy" width="600" height="900" />
        </div>
        <div class="gallery-preview__item" data-reveal data-delay="100">
          <img src="/images/668d713cc42499da19880fec_optimized_1396_c1396x930-0x0.jpg" alt="Before and after" loading="lazy" width="600" height="450" />
        </div>
        <div class="gallery-preview__item" data-reveal data-delay="200">
          <img src="/images/668d72ee927cf1a08b28ecbf_optimized_1475_c1475x881-0x0.jpg" alt="Aesthetic treatment" loading="lazy" width="600" height="450" />
        </div>
        <div class="gallery-preview__item" data-reveal data-delay="300">
          <img src="/images/686bf4fa2fc1c8e963240faf_optimized_1024_c1024x1024-0x0.jpg" alt="Skin treatment result" loading="lazy" width="450" height="450" />
        </div>
        <div class="gallery-preview__item" data-reveal data-delay="400">
          <img src="/images/68751a2a45bbd1f01958dbef_optimized_930_c930x1396-0x0.jpg" alt="Clinic result" loading="lazy" width="450" height="600" />
        </div>
      </div>

      <div class="text-center" style="margin-top:3rem" data-reveal data-delay="200">
        <a href="/gallery" class="btn btn--outline">View Full Gallery</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       TESTIMONIALS
  ═══════════════════════════════════════ -->
  <section class="testimonials section" aria-labelledby="testimonials-heading">
    <div class="testimonials__bg" aria-hidden="true">
      <img src="/images/668c49fc0c795ee329850b2a_optimized_1920.jpg" alt="" loading="lazy" width="1920" height="800" />
      <div class="testimonials__overlay"></div>
    </div>
    <div class="container">
      <div class="section-header text-center" data-reveal="fade">
        <p class="eyebrow" style="color:var(--rose)">Client Love</p>
        <h2 id="testimonials-heading" style="color:var(--cream)">What Our Clients Say</h2>
        <div class="divider"></div>
      </div>

      <div class="testimonials__grid">
        {testimonials.map((t, i) => (
          <div class="testimonial-card" data-reveal data-delay={String((i + 1) * 100)}>
            <div class="testimonial-card__quote-mark" aria-hidden="true">"</div>
            <blockquote>
              <p class="testimonial-card__text">{t.quote}</p>
              <footer class="testimonial-card__author">
                <strong>{t.author}</strong>
                <span>{t.location}</span>
              </footer>
            </blockquote>
            <div class="testimonial-card__stars" aria-label="5 stars">
              ★★★★★
            </div>
          </div>
        ))}
      </div>

      <div class="text-center" style="margin-top:3rem" data-reveal data-delay="300">
        <a href="/testimonials" class="btn btn--outline-white">Read All Reviews</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       BRANDS / PARTNERS
  ═══════════════════════════════════════ -->
  <section class="brands section--sm" aria-labelledby="brands-heading">
    <div class="container">
      <p class="eyebrow text-center" id="brands-heading" data-reveal="fade">Medical-Grade Partners</p>
      <div class="brands__list">
        {brands.map((brand, i) => (
          <div class="brands__item" data-reveal="fade" data-delay={String((i + 1) * 80)}>
            {brand}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SHOP TEASER
  ═══════════════════════════════════════ -->
  <section class="shop-teaser section" aria-labelledby="shop-heading">
    <div class="container">
      <div class="shop-teaser__grid">
        <div class="shop-teaser__content" data-reveal="left">
          <p class="eyebrow">Online Store</p>
          <h2 id="shop-heading">Shop the Secret<br>to Radiant Skin</h2>
          <div class="divider divider--left"></div>
          <p class="lead">
            Discover premium medical-grade skincare from SkinCeuticals®, Vivier Skin, EltaMD and more — curated by our clinical team to complement your treatments and elevate your daily routine.
          </p>
          <p>Easy online ordering with convenient pick-up or delivery. Achieving glowing, youthful-looking skin has never been more accessible.</p>
          <a href="https://labellemedicalclinic.com/shop" target="_blank" rel="noopener" class="btn btn--primary" style="margin-top:2rem">
            Shop Now
          </a>
        </div>
        <div class="shop-teaser__image" data-reveal="right">
          <img
            src="/images/668c47e0bb3c3a7e400c55d9_optimized_582.jpg"
            alt="Medical-grade skincare products"
            loading="lazy"
            width="600"
            height="700"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CTA BANNER
  ═══════════════════════════════════════ -->
  <section class="cta-banner" aria-labelledby="cta-heading">
    <div class="container text-center">
      <p class="eyebrow" style="color:var(--rose)" data-reveal="fade">Start Your Journey</p>
      <h2 id="cta-heading" style="color:var(--cream)" data-reveal data-delay="100">
        Your Path to Confidence<br>Starts Here
      </h2>
      <div class="divider" data-reveal="fade" data-delay="200"></div>
      <p style="color:rgba(255,255,255,0.7); max-width:52ch; margin-inline:auto; font-size:1.05rem;" data-reveal data-delay="200">
        Embrace the confidence that comes with beautiful skin. Book a consultation today and experience personalized care that celebrates your natural radiance.
      </p>
      <div class="cta-banner__actions" data-reveal data-delay="300">
        <a href="https://labellemedicalclinic.janeapp.com/" target="_blank" rel="noopener" class="btn btn--rose">
          Book a Consultation
        </a>
        <a href="tel:5068490271" class="btn btn--outline-white">
          Call 506-849-0271
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ── Hero ── */
.hero {
  position: relative;
  height: 100svh;
  min-height: 600px;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
  transform: scale(1.04);
  animation: heroZoom 12s ease-out forwards;
}
@keyframes heroZoom {
  to { transform: scale(1); }
}
.hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(17,17,17,0.68) 0%,
    rgba(17,17,17,0.38) 60%,
    rgba(17,17,17,0.55) 100%
  );
}
.hero__content {
  position: relative;
  z-index: 1;
  padding-top: 80px;
}
.hero__text {
  max-width: 700px;
}
.hero__eyebrow {
  font-family: 'Open Sans', sans-serif;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--rose);
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: fadeUp 0.8s ease 0.3s forwards;
}
.hero__title {
  color: var(--white);
  font-size: clamp(3.5rem, 8vw, 7.5rem);
  line-height: 1;
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: fadeUp 0.9s ease 0.5s forwards;
}
.hero__title em {
  font-style: italic;
  color: var(--rose-light);
}
.hero__subtitle {
  font-family: 'Open Sans', sans-serif;
  font-size: clamp(1rem, 2vw, 1.2rem);
  font-weight: 300;
  color: rgba(255,255,255,0.8);
  line-height: 1.7;
  margin-bottom: 2.5rem;
  max-width: 54ch;
  opacity: 0;
  animation: fadeUp 0.9s ease 0.7s forwards;
}
.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  opacity: 0;
  animation: fadeUp 0.9s ease 0.9s forwards;
}
.hero__scroll {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  color: rgba(255,255,255,0.5);
  font-family: 'Open Sans', sans-serif;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  animation: fadeIn 1s ease 1.5s both;
}
.hero__scroll-line {
  width: 1px;
  height: 50px;
  background: rgba(255,255,255,0.3);
  position: relative;
  overflow: hidden;
}
.hero__scroll-line::after {
  content: '';
  position: absolute;
  top: -100%;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--rose);
  animation: scrollLine 2s ease-in-out infinite;
}
@keyframes scrollLine {
  to { top: 100%; }
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: none; }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ── Trust Bar ── */
.trust-bar {
  background: var(--charcoal);
  padding: 1.25rem 0;
}
.trust-bar__list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.5rem 2.5rem;
}
.trust-bar__item {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-family: 'Open Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.75);
}
.trust-bar__icon { color: var(--rose); font-size: 0.5rem; }

/* ── About Intro ── */
.about-intro__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(3rem, 6vw, 6rem);
  align-items: center;
}
.about-intro__images {
  position: relative;
  height: 600px;
}
.about-intro__img-wrap {
  position: absolute;
  overflow: hidden;
}
.about-intro__img-wrap--main {
  top: 0;
  left: 0;
  width: 75%;
  height: 100%;
  box-shadow: var(--shadow-lg);
}
.about-intro__img-wrap--accent {
  bottom: -3rem;
  right: 0;
  width: 38%;
  height: 55%;
  box-shadow: var(--shadow-lg);
  border: 6px solid var(--cream);
}
.about-intro__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s var(--ease);
}
.about-intro__img-wrap:hover img { transform: scale(1.04); }


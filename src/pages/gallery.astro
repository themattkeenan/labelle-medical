---

<Layout
  title="Gallery — Treatment Results & Clinic Photos"
  description="Browse La Belle Medical Aesthetic Clinic's gallery of treatment results, before & after photos, and our beautiful clinic in Quispamsis, NB."
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero__bg">
      <img src="/images/686bf6e947e5bf66827f26f1_optimized_1920_c1230x818-377x82.jpg" alt="Gallery" loading="eager" fetchpriority="high" width="1230" height="818" />
      <div class="page-hero__overlay"></div>
    </div>
    <div class="container page-hero__content text-center">
      <p class="eyebrow" style="color:var(--rose)">Results Speak</p>
      <h1 style="color:var(--white)">Our Gallery</h1>
      <div class="divider"></div>
      <p style="color:rgba(255,255,255,0.8); max-width:48ch; margin-inline:auto;">Real results from real clients. Every image tells a story of confidence restored and beauty celebrated.</p>
    </div>
  </section>

  <!-- Masonry Gallery -->
  <section class="section">
    <div class="container">
      <div class="masonry-grid">
        {images.map((img, i) => (
          <div
            class:list={['masonry-item', `masonry-item--${img.aspect}`]}
            data-reveal="fade"
            data-delay={String((i % 5) * 100)}
          >
            <div class="masonry-item__inner">
              <img
                src={img.src}
                alt={img.alt}
                loading="lazy"
                width="600"
                height={img.aspect === 'portrait' ? 800 : img.aspect === 'square' ? 600 : 400}
              />
              <div class="masonry-item__overlay">
                <span class="masonry-item__zoom" aria-hidden="true">+</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section text-center" style="background:var(--charcoal)">
    <div class="container">
      <p class="eyebrow" style="color:var(--rose)" data-reveal="fade">Your Results Await</p>
      <h2 style="color:var(--cream)" data-reveal data-delay="100">Ready for Your Transformation?</h2>
      <div class="divider" data-reveal="fade" data-delay="200"></div>
      <a href="https://labellemedicalclinic.janeapp.com/" target="_blank" rel="noopener" class="btn btn--rose" style="margin-top:1.5rem" data-reveal data-delay="300">Book a Consultation</a>
    </div>
  </section>

</Layout>

<style>
.page-hero {
  position: relative;
  height: 60vh;
  min-height: 400px;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.page-hero__bg { position: absolute; inset: 0; }
.page-hero__bg img { width: 100%; height: 100%; object-fit: cover; }
.page-hero__overlay { position: absolute; inset: 0; background: rgba(17,17,17,0.6); }
.page-hero__content { position: relative; z-index: 1; padding-top: 80px; }

.masonry-grid {
  columns: 4 260px;
  column-gap: 1rem;
}
.masonry-item {
  break-inside: avoid;
  margin-bottom: 1rem;
  cursor: pointer;
}
.masonry-item__inner {
  position: relative;
  overflow: hidden;
}
.masonry-item__inner img {
  width: 100%;
  height: auto;
  display: block;
  transition: transform 0.6s var(--ease);
}
.masonry-item:hover .masonry-item__inner img { transform: scale(1.05); }
.masonry-item__overlay {
  position: absolute;
  inset: 0;
  background: rgba(17,17,17,0);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.4s ease;
}
.masonry-item:hover .masonry-item__overlay { background: rgba(17,17,17,0.35); }
.masonry-item__zoom {
  color: var(--white);
  font-size: 2.5rem;
  opacity: 0;
  transform: scale(0.6);
  transition: opacity 0.3s ease, transform 0.3s ease;
  font-weight: 300;
}
.masonry-item:hover .masonry-item__zoom {
  opacity: 1;
  transform: scale(1);
}

@media (max-width: 600px) {
  .masonry-grid { columns: 2 160px; }
}
</style>

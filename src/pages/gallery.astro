  { src: '/images/6866d8b823379be9c1e4bf4d_optimized_1398_c1398x930-0x0.jpg', alt: 'Medical aesthetics', aspect: 'landscape' },
  { src: '/images/686bc870fc98b09e4ae01b7d_optimized_1920.jpg', alt: 'La Belle clinic', aspect: 'landscape' },
  { src: '/images/686bf4fa2fc1c8e963240faf_optimized_1024_c1024x1024-0x0.jpg', alt: 'Skin treatment', aspect: 'square' },
  { src: '/images/686bf6e947e5bf66827f26f1_optimized_1920_c1230x818-377x82.jpg', alt: 'Beauty result', aspect: 'landscape' },
  { src: '/images/686bf710e674fd2580bf39b3_optimized_1398.jpg', alt: 'Treatment result', aspect: 'landscape' },

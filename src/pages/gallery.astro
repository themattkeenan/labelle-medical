  { src: '/images/6866d81ccd186242532d7d09_optimized_929_c929x1396-0x0.jpg', alt: 'Skin result', aspect: 'portrait' },
  { src: '/images/6866d83043cdf93d3f9a5f28_optimized_1019_c1019x1273-0x0.jpg', alt: 'Aesthetic treatment', aspect: 'portrait' },

---
const services = [
  { label: 'Botox® & Dysport®', href: '/services/botox-dysport' },
  { label: 'Dermal Fillers', href: '/services/dermal-fillers' },
  { label: 'Sculptra®', href: '/services/sculptra' },
  { label: 'Laser Treatments', href: '/services/laser-treatments' },
  { label: 'Microneedling', href: '/services/microneedling' },
  { label: 'PRP Therapy', href: '/services/prp' },
  { label: 'Chemical Peels', href: '/services/chemical-peels' },
  { label: 'Latisse®', href: '/services/latisse' },
  { label: 'Sclerotherapy', href: '/services/sclerotherapy' },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <!-- Top wave -->
  <div class="footer__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,60 L0,60 Z" fill="#1a1a1a"/>
    </svg>
  </div>

  <div class="footer__body">
    <div class="container">
      <div class="footer__grid">

        <!-- Brand column -->
        <div class="footer__brand">
          <a href="/" class="footer__logo" aria-label="La Belle Medical Aesthetic Clinic">
            <img
              src="/images/668c47e0bb3c3a7e400c55d9_optimized_582.webp"
              alt="La Belle Medical Aesthetic Clinic"
              width="200"
              height="122"
              loading="lazy"
              style="height:60px;width:auto;object-fit:contain;filter:brightness(0) invert(1);"
            />
          </a>
          <p class="footer__tagline">
            Luxury skin treatments and medical aesthetics in Quispamsis, New Brunswick. Nurse Practitioner-owned, dedicated to your natural beauty.
          </p>
          <div class="footer__social">
            <a href="https://www.facebook.com/La.Belle.Medical.Aesthetic" target="_blank" rel="noopener" aria-label="Facebook" class="footer__social-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://www.instagram.com/labellemedicalclinic/" target="_blank" rel="noopener" aria-label="Instagram" class="footer__social-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="mailto:Labellemedclinic@gmail.com" aria-label="Email" class="footer__social-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </a>
          </div>
        </div>

        <!-- Services -->
        <div class="footer__col">
          <p class="footer__heading">Services</p>
          <ul class="footer__links">
            {services.map(s => (
              <li><a href={s.href} class="footer__link">{s.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Navigation -->
        <div class="footer__col">
          <p class="footer__heading">Navigate</p>
          <ul class="footer__links">
            <li><a href="/about" class="footer__link">About Us</a></li>
            <li><a href="/services" class="footer__link">All Services</a></li>
            <li><a href="/gallery" class="footer__link">Gallery</a></li>
            <li><a href="/testimonials" class="footer__link">Testimonials</a></li>
            <li><a href="/contact" class="footer__link">Contact</a></li>
            <li><a href="https://labellemedicalclinic.janeapp.com/" target="_blank" rel="noopener" class="footer__link">Book Appointment</a></li>
            <li><a href="/financing" class="footer__link">Financing</a></li>
            <li><a href="/privacy-policy" class="footer__link">Privacy Policy</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div class="footer__col">
          <p class="footer__heading">Visit Us</p>
          <address class="footer__address">
            <p>208 Hampton Rd<br>Quispamsis, NB&nbsp;&nbsp;E2E 4L8</p>
          </address>
          <div class="footer__contact-items">
            <a href="tel:5068490271" class="footer__contact-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.38 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 6.29 6.29l.97-.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              506-849-0271
            </a>
            <a href="mailto:Labellemedclinic@gmail.com" class="footer__contact-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              Labellemedclinic@gmail.com
            </a>
          </div>
          <div class="footer__areas">
            <p class="footer__areas-label">Serving</p>
            <p>Quispamsis · Saint John · Hampton · Sussex · Fredericton</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <p>&copy; {year} La Belle Medical Aesthetic Clinic. All rights reserved.</p>
      <p class="footer__credit">Quispamsis, New Brunswick, Canada</p>
    </div>
  </div>
</footer>

<style>
.footer { position: relative; }

.footer__wave {
  line-height: 0;
}
.footer__wave svg {
  width: 100%;
  height: 60px;
  display: block;
}

.footer__body {
  background: #1a1a1a;
  padding: 5rem 0 4rem;
}

.footer__grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 3rem;
}

.footer__logo {
  display: inline-block;
  margin-bottom: 1.5rem;
  transition: opacity 0.3s ease;
}
.footer__logo:hover { opacity: 0.8; }

.footer__tagline {
  font-family: 'Open Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 300;
  line-height: 1.8;
  color: rgba(255,255,255,0.72);
  max-width: 30ch;
  margin-bottom: 1.5rem;
}

.footer__social {
  display: flex;
  gap: 0.75rem;
}
.footer__social-link {
  display: grid;
  place-items: center;
  width: 38px;
  height: 38px;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 50%;
  color: rgba(255,255,255,0.6);
  transition: all 0.3s ease;
}
.footer__social-link:hover {
  color: var(--rose);
  border-color: var(--rose);
  transform: translateY(-3px);
}

.footer__heading {
  font-family: 'Open Sans', sans-serif;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--rose);
  margin-bottom: 1.25rem;
}

.footer__links {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.footer__link {
  font-family: 'Open Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 300;
  color: rgba(255,255,255,0.72);
  transition: color 0.3s ease;
}
.footer__link:hover { color: var(--cream); }

.footer__address {
  font-style: normal;
  margin-bottom: 1.25rem;
}
/* explicit p rule to beat global body color cascade */
.footer__address p {
  font-family: 'Open Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 300;
  line-height: 1.8;
  color: rgba(255,255,255,0.78);
  max-width: none;
}

.footer__contact-items {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  margin-bottom: 1.5rem;
}
.footer__contact-link {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-family: 'Open Sans', sans-serif;
  font-size: 0.82rem;
  color: rgba(255,255,255,0.78);
  transition: color 0.3s ease;
}
.footer__contact-link:hover { color: var(--rose); }

.footer__areas {
  padding-top: 1.25rem;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.footer__areas-label {
  font-family: 'Open Sans', sans-serif;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.72);
  margin-bottom: 0.5rem;
  max-width: none;
}
.footer__areas p:last-child {
  font-family: 'Open Sans', sans-serif;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.72);
  max-width: none;
}

.footer__bottom {
  background: #111;
  padding: 1.5rem 0;
}
.footer__bottom .container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.footer__bottom p {
  font-family: 'Open Sans', sans-serif;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.65);
  max-width: none;
}

@media (max-width: 1024px) {
  .footer__grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  .footer__brand { grid-column: 1 / -1; }
}
@media (max-width: 640px) {
  .footer__grid { grid-template-columns: 1fr; }
  .footer__body { padding: 3.5rem 0 3rem; }
  .footer__bottom .container { flex-direction: column; text-align: center; }
}
</style>
